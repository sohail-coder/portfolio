        </li>\r\n          {/* <li>\r\n            <a className=\"smoothscroll\" href=\"#resume\">\r\n              Resume\r\n            </a>\r\n          </li> */}\r\n          <li>\r\n            <a className=\"smoothscroll\" href=\"#portfolio\">\r\n              Works\r\n            </a>\r\n          </li>\r\n          {/* <li>\r\n            <a className=\"smoothscroll\" href=\"#testimonials\">\r\n              Testimonials\r\n            </a>\r\n          </li> */}\r\n          <li>\r\n            <a className=\"smoothscroll\" href=\"#contact\">\r\n              Contact\r\n            </a>\r\n          </li>\r\n        </ul>\r\n      </nav>\r\n\r\n      <div className=\"row banner\">\r\n        <div className=\"banner-text\">\r\n          <h1 className=\"responsive-headline\">\r\n            <TypeWriter typing={0.5}>{name ? `I'm ${name}.` : null}</TypeWriter>\r\n          </h1>\r\n          <h3>\r\n            <span>{occupation}</span>.\r\n          </h3>\r\n          <hr />\r\n          <ul className=\"social\">{networks}</ul>\r\n        </div>\r\n      </div>\r\n\r\n      <p className=\"scrolldown\">\r\n        <a className=\"smoothscroll\" href=\"#about\">\r\n          <i className=\"icon-down-circle\"></i>\r\n        </a>\r\n      </p>\r\n    </header>\r\n  );\r\n};\r\n\r\nexport default Header;\r\n","D:\\portfolio\\src\\Components\\About.js",[],"D:\\portfolio\\src\\Components\\Portfolio.js",[],"D:\\portfolio\\src\\Components\\Footer.js",["48"],"D:\\portfolio\\src\\Components\\Contact.js",[],{"ruleId":"49","replacedBy":"50"},{"ruleId":"51","replacedBy":"52"},{"ruleId":"53","severity":1,"message":"54","line":8,"column":9,"nodeType":"55","messageId":"56","endLine":8,"endColumn":20},{"ruleId":"53","severity":1,"message":"57","line":9,"column":9,"nodeType":"55","messageId":"56","endLine":9,"endColumn":13},{"ruleId":"58","severity":1,"message":"59","line":25,"column":15,"nodeType":"60","endLine":25,"endColumn":42},"no-native-reassign",["61"],"no-negated-in-lhs",["62"],"no-unused-vars","'description' is assigned a value but never used.","Identifier","unusedVar","'city' is assigned a value but never used.","jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","no-global-assign","no-unsafe-negation"]